/* 虾仔 - 全局样式 */

page {
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", "PingFang SC", "Microsoft YaHei", sans-serif;
  background-color: #F5F0EB;
  color: #2D2D2D;
  box-sizing: border-box;
}

/* 通用按钮 */
.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  padding: 28rpx 0;
  background: #2D2D2D;
  color: #F5F0EB;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 48rpx;
  border: none;
  transition: opacity 0.2s;
}

.btn-primary:active {
  opacity: 0.8;
}

.btn-secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  padding: 24rpx 0;
  background: transparent;
  color: #2D2D2D;
  font-size: 30rpx;
  border-radius: 48rpx;
  border: 2rpx solid #2D2D2D;
}

.btn-secondary:active {
  opacity: 0.7;
}

/* 页面容器 */
.page-container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding: 0 32rpx;
}

/* 标题 */
.page-title {
  font-size: 52rpx;
  font-weight: 600;
  color: #2D2D2D;
  line-height: 1.3;
  margin-bottom: 16rpx;
}

.page-subtitle {
  font-size: 28rpx;
  color: #8C8C8C;
  line-height: 1.5;
  margin-bottom: 48rpx;
}

/* 分隔线 */
.divider {
  width: 100%;
  height: 2rpx;
  background: #E8E2DA;
  margin: 32rpx 0;
}

/* 卡片 */
.card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}