/* 聊天页样式 */

.chat-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F5F0EB;
}

/* 顶部导航 */
.chat-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  padding-top: calc(88rpx + env(safe-area-inset-top));
  background: #F5F0EB;
  border-bottom: 2rpx solid #E8E2DA;
  flex-shrink: 0;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.header-emoji {
  font-size: 48rpx;
}

.header-info {
  display: flex;
  flex-direction: column;
}

.header-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #2D2D2D;
}

.header-mode {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
  margin-top: 4rpx;
}

.mode-white {
  background: rgba(141, 110, 99, 0.12);
  color: #8D6E63;
}

.mode-black {
  background: #2D2D2D;
  color: #F5F0EB;
}

.header-right {
  flex-shrink: 0;
}

.switch-btn {
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
  border: 2rpx solid #2D2D2D;
  font-size: 24rpx;
  color: #2D2D2D;
}

.switch-btn:active {
  opacity: 0.7;
}

.switch-active {
  background: #2D2D2D;
  color: #F5F0EB;
}

.switch-label {
  display: block;
}

/* 消息列表 */
.message-list {
  flex: 1;
  overflow-y: auto;
  padding: 32rpx;
  -webkit-overflow-scrolling: touch;
}

/* 欢迎卡 */
.welcome-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 32rpx;
  text-align: center;
}

.welcome-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #2D2D2D;
  margin-bottom: 20rpx;
}

.welcome-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.welcome-hint {
  font-size: 26rpx;
  color: #B8B8B8;
}

/* 消息行 */
.message-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.row-user {
  flex-direction: row-reverse;
}

.row-assistant {
  flex-direction: row;
}

/* 头像 */
.avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  flex-shrink: 0;
}

.avatar-user {
  background: #2D2D2D;
  color: #F5F0EB;
}

.avatar-shrimp {
  background: #E8E2DA;
  font-size: 32rpx;
}

/* 气泡 */
.bubble {
  max-width: 70%;
  padding: 24rpx 28rpx;
  border-radius: 28rpx;
  position: relative;
}

.bubble-user {
  background: #2D2D2D;
  border-bottom-right-radius: 8rpx;
}

.bubble-user .bubble-text {
  color: #F5F0EB;
}

.bubble-assistant {
  background: #FFFFFF;
  border-bottom-left-radius: 8rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.bubble-text {
  font-size: 30rpx;
  line-height: 1.7;
  color: #2D2D2D;
  word-break: break-word;
}

.bubble-time {
  font-size: 20rpx;
  color: #B8B8B8;
  margin-top: 8rpx;
  text-align: right;
}

.bubble-user .bubble-time {
  color: rgba(245, 240, 235, 0.6);
}

/* 加载动画 */
.bubble-loading {
  padding: 28rpx 32rpx;
}

.loading-dots {
  display: flex;
  gap: 8rpx;
  align-items: center;
}

.dot {
  width: 14rpx;
  height: 14rpx;
  background: #B8B8B8;
  border-radius: 50%;
  animation: bounce 1.4s infinite ease-in-out both;
}

.dot:nth-child(1) {
  animation-delay: -0.32s;
}

.dot:nth-child(2) {
  animation-delay: -0.16s;
}

.dot:nth-child(3) {
  animation-delay: 0s;
}

@keyframes bounce {
  0%, 80%, 100% {
    transform: scale(0.6);
    opacity: 0.4;
  }
  40% {
    transform: scale(1);
    opacity: 1;
  }
}

/* 底部输入区 */
.input-area {
  flex-shrink: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  background: #F5F0EB;
  border-top: 2rpx solid #E8E2DA;
}

.input-wrapper {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #FFFFFF;
  border-radius: 48rpx;
  padding: 8rpx 8rpx 8rpx 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.text-input {
  flex: 1;
  height: 72rpx;
  font-size: 30rpx;
  color: #2D2D2D;
  background: transparent;
}

.send-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 120rpx;
  height: 72rpx;
  border-radius: 40rpx;
  background: #E8E2DA;
  color: #B8B8B8;
  font-size: 28rpx;
  border: none;
  padding: 0;
}

.send-active {
  background: #2D2D2D;
  color: #F5F0EB;
}

.send-btn:disabled {
  opacity: 1;
}

.input-hint {
  display: block;
  text-align: center;
  font-size: 20rpx;
  color: #C8C8C8;
  margin-top: 16rpx;
}

.link {
  color: #8D6E63;
  text-decoration: underline;
}