<view class="history-container">
  <view class="history-header">
    <text class="history-title">历史对话</text>
    <text class="history-clear" bindtap="clearHistory">清空</text>
  </view>

  <view class="empty-state" wx:if="{{sessions.length === 0}}">
    <text class="empty-icon">🦐</text>
    <text class="empty-text">还没有对话记录</text>
    <text class="empty-hint">去和虾仔聊聊吧</text>
  </view>

  <view class="session-list" wx:else>
    <view class="session-item" wx:for="{{sessions}}" wx:key="id" bindtap="openSession" data-id="{{item.id}}">
      <view class="session-left">
        <text class="session-preview">{{item.preview}}</text>
        <text class="session-time">{{item.time}}</text>
      </view>
      <view class="session-mode {{item.mode === 'blackShrimp' ? 'mode-black' : 'mode-white'}}">
        {{item.mode === 'blackShrimp' ? '黑虾' : '白虾'}}
      </view>
    </view>
  </view>
</view>